{
  "name": "api-immoplus",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build && cp -r views dist/views && cp -r public dist/public && cp -r src/templates dist/src/templates",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "migrate": "tsc && npm run typeorm -- migration:run",
    "seeder": "typeorm schema:run seeder",
    "seed:villes": "ts-node -r tsconfig-paths/register scripts/run-seed-villes.ts",
    "seed:communes": "ts-node -r tsconfig-paths/register scripts/run-seed-communes.ts",
    "verify:migrations": "ts-node -r tsconfig-paths/register scripts/verify-migrations.ts",
    "fix:wallet-migration": "ts-node -r tsconfig-paths/register scripts/fix-wallet-migration.ts",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "node --inspect-brk -r ts-node/register -r tsconfig-paths/register ./src/main.ts",
    "start:prod": "node dist/src/main",
    "dev": "nest start --watch",
    "debug": "npm run start:debug",
    "typeorm": "ts-node -r tsconfig-paths/register ./node_modules/typeorm/cli.js -d ./src/infrastructure/typeorm/data-source.ts",
    "migration:generate": "npx typeorm migration:generate",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "test:video": "K6_WEB_DASHBOARD=true k6 run stress-tests/video-upload-test.js",
    "test:image": "K6_WEB_DASHBOARD=true k6 run stress-tests/image-upload-test.js",
    "test:load": "K6_WEB_DASHBOARD=true API_URL=https://api.immoplus.ci k6 run stress-tests/load-test.js",
    "test:soak": "K6_WEB_DASHBOARD=true API_URL=https://api.immoplus.ci k6 run stress-tests/soak-test.js",
    "test:spike": "K6_WEB_DASHBOARD=true API_URL=https://api.immoplus.ci k6 run stress-tests/spike-test.js",
    "test:stress": "K6_WEB_DASHBOARD=true API_URL=https://api.immoplus.ci k6 run stress-tests/stree-test.js"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.937.0",
    "@aws-sdk/s3-request-presigner": "^3.937.0",
    "@nestjs/common": "^10.3.2",
    "@nestjs/config": "^3.0.0",
    "@nestjs/core": "^10.3.2",
    "@nestjs/cqrs": "^10.2.7",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/microservices": "^10.1.2",
    "@nestjs/passport": "^10.0.0",
    "@nestjs/platform-express": "^10.3.2",
    "@nestjs/schedule": "^4.1.2",
    "@nestjs/swagger": "^11.2.5",
    "@nestjs/throttler": "^6.0.0",
    "@nestjs/typeorm": "^10.0.0",
    "@nestjsx/crud": "^5.0.0-alpha.3",
    "@nestjsx/crud-typeorm": "^5.0.0-alpha.3",
    "axios": "^1.7.2",
    "bcrypt": "^5.1.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "command-line-args": "^5.2.1",
    "command-line-usage": "^7.0.1",
    "compression": "^1.7.4",
    "dotenv": "^16.3.1",
    "express": "^5.1.0",
    "figlet": "^1.6.0",
    "google-auth-library": "^10.5.0",
    "hbs": "^4.2.0",
    "inflection": "^2.0.1",
    "joi": "^17.9.2",
    "jsonwebtoken": "^9.0.0",
    "minio": "^8.0.6",
    "moment": "^2.30.1",
    "mysql2": "^3.10.3",
    "nanoid": "^5.0.7",
    "nestjs-i18n": "^10.2.6",
    "nodemailer": "^7.0.10",
    "passport": "^0.6.0",
    "passport-facebook": "^3.0.0",
    "passport-google-oauth20": "^2.0.0",
    "passport-jwt": "^4.0.1",
    "passport-local": "^1.0.0",
    "pg": "^8.11.0",
    "reflect-metadata": "^0.2.1",
    "rxjs": "^7.8.1",
    "swagger": "^0.0.1",
    "twilio": "^5.3.6",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@faker-js/faker": "^8.4.1",
    "@nestjs/cli": "^11.0.10",
    "@nestjs/schematics": "^10.1.0",
    "@nestjs/testing": "^10.4.17",
    "@swc/cli": "^0.7.8",
    "@swc/core": "^1.4.0",
    "@types/bcrypt": "^5.0.0",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.11.16",
    "@types/passport-jwt": "^4.0.1",
    "@types/supertest": "^6.0.2",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.3",
    "jest": "^26.5.3",
    "k6": "^0.0.0",
    "prettier": "^3.2.5",
    "source-map-support": "^0.5.21",
    "supertest": "^6.3.4",
    "ts-jest": "^26.5.6",
    "ts-loader": "^9.5.1",
    "ts-node": "^1.7.1",
    "tsconfig-paths": "^4.2.0",
    "typeorm": "^0.3.1",
    "typescript": "^5.3.3",
    "zod": "^3.23.8"
  }
}
