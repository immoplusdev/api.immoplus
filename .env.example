# SMS
SMS_SENDER_NAME=example_sms_sender

# MAILING
NODE_MAILER_HOST=example.mail.host
NODE_MAILER_PORT=587
NODE_MAILER_USER=example_mail_user
NODE_MAILER_PASSWORD=example_mail_password
NODE_MAILER_FROM=example@domain.com
NODE_MAILER_SECURE=false
NODE_MAILER_IGNORE_TLS=false
NODE_MAILER_PROTOCOL=smtp

# UPLOADS
NEST_PORT=3000
NEST_UPLOAD_DIR=./uploads
NEST_CONTAINER_NAME=example_nest_container
NEST_APP_PROFILE=dev
NEST_SWAGGER_ENABLED=true
NEST_APP_ADMIN_PASSWORD_ID=example-admin-password-id
NEST_APP_ADMIN_PASSWORD_HASH=example_admin_password_hash

#K6
K6_API_URL=http://localhost:3000
K6_PRO_USERNAME=example_k6_user
K6_PRO_PASSWORD=example_k6_password

