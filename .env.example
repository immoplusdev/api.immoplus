# Mysql Production - Digital Ocean
DB_CLIENT=mysql
DB_HOST=example.prod.mysql.host
DB_PORT=3306
DB_DATABASE=example_prod_db
DB_USER=example_prod_user
DB_PASSWORD=example_prod_password
DB_SSL_ENABLED=false
DB_SSL_CA_PATH=./ca-certificate.crt
DB_SSL_REJECT_UNAUTHORIZED=true

