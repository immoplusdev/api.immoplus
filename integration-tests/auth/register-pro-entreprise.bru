meta {
  name: register-pro-entreprise
  type: http
  seq: 1
}

post {
  url: {{API_URL}}/auth/register-pro-entreprise
  body: json
  auth: none
}

body:json {
  {
    "email": "pro-enteprise-{{userId}}@immoplus.ci",
    "avatar": "{{DEFAULT_IMAGE_ID}}",
    "phoneNumber": "225{{userId}}",
    "password": "{{DEFAULT_USER_PASSWORD}}",
    "nomEntreprise": "NomEntreprise",
    "emailEntreprise": "test@gmail.com",
    "registreCommerceId": "{{DEFAULT_IMAGE_ID}}",
    "numeroContribuable": "string",
    "typeEntreprise": "string"
  }
}

script:pre-request {
  const { faker } = require('@faker-js/faker');
  bru.setVar("userId", faker.string.numeric(10));
  
}

tests {
  test("Should receive a not null registreCommerceId", function() {
    const {data: { user: { additionalData }}} = res.getBody();
  
    expect(additionalData.registreCommerceId).to.be.a('string');
  });
}
