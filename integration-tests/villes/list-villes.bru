meta {
  name: list-villes
  type: http
  seq: 2
}

get {
  url: {{API_URL}}/villes
  body: none
  auth: none
}

tests {
  test("Should receive a none empty list of date objects", function() {
    const { data } = res.getBody();
      
    expect(Array.isArray(data)).to.be.equal(true);
    
    if(data.length != 0){
      expect(data.at(0).name).to.be.a("string");
    }
  });
}
