meta {
  name: register-customer
  type: http
  seq: 7
}

post {
  url: {{API_URL}}/auth/register-customer
  body: json
  auth: none
}

body:json {
  {
    "email": "customer-{{userId}}@immoplus.ci",
    "firstName": "{{userId}}",
    "lastName": "{{userId}}",
    "phoneNumber": "225-{{userId}}",
    "password": "{{DEFAULT_USER_PASSWORD}}"
  }
}

script:pre-request {
  const { faker } = require('@faker-js/faker');
  bru.setVar("userId", faker.string.numeric(10));
  
}

tests {
  test("Should receive a not null registreCommerceId", function() {
    const {data: { user: { additionalData }}} = res.getBody();
  
    expect(additionalData.registreCommerceId).to.be.a('string');
  });
}
