meta {
  name: update-bien-immobilier
  type: http
  seq: 3
}

patch {
  url: {{API_URL}}/biens-immobiliers/{{DEFAULT_BIEN_IMMOBILIER_ID}}
  body: json
  auth: bearer
}

auth:bearer {
  token: {{proToken}}
}

body:json {
  { 
    "nom": "{{name}}",
    "bienImmobilierDisponible": false
  } 
}

script:pre-request {
  const { faker } = require('@faker-js/faker');
  bru.setVar("name", faker.company.name());
  
  
  
  
  
  
}

tests {
  test("Should receive a not null id", function() {
    const {data: { nom }} = res.getBody();
    const newName = bru.getVar("name");
    expect(newName == nom).to.be.equal(true);
  });
}
