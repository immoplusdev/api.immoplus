meta {
  name: create-bien-immobilier
  type: http
  seq: 1
}

post {
  url: {{API_URL}}/biens-immobiliers
  body: json
  auth: bearer
}

auth:bearer {
  token: {{proToken}}
}

body:json {
  {
    "miniature": "{{DEFAULT_IMAGE_ID}}",
    "nom": "{{residenceName}}",
    "typeBienImmobilier": "terrain",
    "description": "{{name}}",
    "prix": {{prix}},
    "adresse": "{{name}}",
    "ville": "{{DEFAULT_VILLE_ID}}",
    "commune": "{{DEFAULT_COMMUNE_ID}}",
    "position": {
      "type": "Point",
      "coordinates": [{{lat}}, {{long}}]
    },
    "tags": [
      "{{name}}"
    ],
    "video": "{{DEFAULT_IMAGE_ID}}",
    "images": [
      "{{DEFAULT_IMAGE_ID}}"
    ],
    "metadata": { "ok": "ok"},
    "nombreMaxOccupants": 20,
    "animauxAutorises": true,
    "fetesAutorises": true,
    "reglesSupplementaires": "{{name}}",
    "bienImmobilierDisponible": true
  }
}

script:pre-request {
  const { faker } = require('@faker-js/faker');
  bru.setVar("name", faker.company.name());
  
  bru.setVar("prix", faker.finance.amount({ min: 1, max: 6, dec: 0 }))
  
  const [lat, long] = faker.location.nearbyGPSCoordinate();
  bru.setVar("lat", lat);
  bru.setVar("long", long);
  
  bru.setVar("word", faker.word.adjective())
  
  
  
  
  
  
}

script:post-response {
  const {data: { id }} = res.getBody();
  bru.setEnvVar("DEFAULT_BIEN_IMMOBILIER_ID", id)
}

tests {
  test("Should receive a not null id", function() {
    const {data: { id }} = res.getBody();
  
    expect(id).to.be.a('string');
  });
}
