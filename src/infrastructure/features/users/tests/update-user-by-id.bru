meta {
  name: update-user-by-id
  type: http
  seq: 4
}

patch {
  url: {{API_URL}}/users/{{customerId}}
  body: json
  auth: bearer
}

auth:bearer {
  token: {{customerToken}}
}

body:json {
  {
    "avatar": "{{DEFAULT_IMAGE_ID}}"
  }
}

script:pre-request {
  const { faker } = require('@faker-js/faker');
  bru.setVar("name", faker.company.name());
}
