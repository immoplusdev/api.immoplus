meta {
  name: get-pro-data
  type: http
  seq: 1
}

get {
  url: {{API_URL}}/users/data/me
  body: json
  auth: bearer
}

auth:bearer {
  token: {{accessToken}}
}

script:pre-request {
  const axios = require("axios");
  const { getUserToken } = require("./environments/get-user-token.bru");
  
  const username = bru.getEnvVar("PRO_ENTREPRISE_USERNAME");
  const password = bru.getEnvVar("DEFAULT_USER_PASSWORD");
  
  const token = await getUserToken(username, password);
  bru.setVar("accessToken", token)
}

tests {
  test("Should return not null id and additionalData id", function() {
    const {data} = res.getBody();
  
    expect(data?.additionalData.id).to.be.a('string');
    expect(data.email).to.be.a('string');
  });
}
