meta {
  name: get-user-by-id
  type: http
  seq: 3
}

get {
  url: {{API_URL}}/users/{{customerId}}
  body: json
  auth: bearer
}

auth:bearer {
  token: {{customerToken}}
}

tests {
  test("Should return a none empty data list", function() {
    const {data: { id }} = res.getBody();
  
    expect(id).to.be.a("string");
  });
}
