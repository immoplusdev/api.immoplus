meta {
  name: get-reservations-by-owner
  type: http
  seq: 5
}

get {
  url: {{API_URL}}/reservations/data/residence/owner/{{proId}}
  body: none
  auth: bearer
}

auth:bearer {
  token: {{proToken}}
}

tests {
  test("Should receive a none empty list of date objects", function() {
    const { data } = res.getBody();
      
    expect(Array.isArray(data)).to.be.equal(true);
    
    if(data.length != 0){
      expect(data.at(0).residenceId).to.be.a("string");
    }
  });
}
