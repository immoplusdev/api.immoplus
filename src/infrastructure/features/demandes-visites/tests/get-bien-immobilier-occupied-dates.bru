meta {
  name: get-bien-immobilier-occupied-dates
  type: http
  seq: 2
}

get {
  url: {{API_URL}}/demandes-visites/data/bien-immobilier/occupied-dates/{{DEFAULT_BIEN_IMMOBILIER_ID}}
  body: none
  auth: none
}

tests {
  test("Should receive a list of date objects", function() {
    const {data: { dates }} = res.getBody();
      
    expect(Array.isArray(dates)).to.be.equal(true);
  });
}
