meta {
  name: create-ville
  type: http
  seq: 1
}

post {
  url: {{API_URL}}/villes
  body: json
  auth: bearer
}

auth:bearer {
  token: {{adminToken}}
}

body:json {
  {
    "name": "{{name}}"
  }
}

script:pre-request {
  const { faker } = require('@faker-js/faker');
  bru.setVar("name", faker.location.city());
  
  
  
  
}

