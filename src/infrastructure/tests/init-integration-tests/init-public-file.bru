meta {
  name: init-public-file
  type: http
  seq: 2
}

post {
  url: {{API_URL}}/files/public
  body: multipartForm
  auth: bearer
}

auth:bearer {
  token: {{accessToken}}
}

body:multipart-form {
  file: @file(./environments/image.png)
}

script:post-response {
  const {data: { id }} = res.getBody();
  bru.setEnvVar("DEFAULT_IMAGE_ID", id)
}

tests {
  test("Should receive a not null id", function() {
    const {data: { id }} = res.getBody();
  
    expect(id).to.be.a('string');
  });
}
