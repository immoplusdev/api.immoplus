<html lang="fr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>Bienvenue sur Immo+</title>
    <style>
      body {
        margin: 0;
        padding: 0;
        background: #f5f7fa;
        font-family: Arial, Helvetica, sans-serif;
      }
      .wrap {
        width: 100%;
        background: #f5f7fa;
        padding: 20px 0;
      }
      .container {
        max-width: 600px;
        margin: 0 auto;
        background: #ffffff;
        border-radius: 12px;
        overflow: hidden;
      }
      .header {
        background: linear-gradient(90deg, #2745dc, #2745dc);
        padding: 28px;
        text-align: center;
        color: #fff;
      }
      .top-banner,
      .final-banner-bottom {
        width: 100%;
        overflow: hidden;
      }
      .top-banner img,
      .final-banner-bottom img {
        display: block;
        max-width: 100%;
        height: auto;
        border: 0;
        border-radius: 12px 12px 0 0;
      }
      .final-banner-bottom img {
        border-radius: 0 0 12px 12px;
      }
      .content {
        padding: 28px;
        color: #333;
        font-size: 16px;
        line-height: 1.5;
        text-align: center;
      }
      .btn {
        display: inline-block;
        background: #2745dc;
        color: #fff;
        padding: 12px 20px;
        border-radius: 6px;
        text-decoration: none;
        font-weight: 700;
      }
      .footer {
        padding: 18px;
        text-align: center;
        font-size: 13px;
        color: #777;
        line-height: 1.5;
      }
      .footer a {
        color: #2745dc;
        text-decoration: none;
      }
      @media (max-width: 480px) {
        .content {
          padding: 18px;
        }
        .header {
          padding: 20px;
        }
      }
    </style>
  </head>
  <body>
    <table role="presentation" class="wrap" width="100%">
      <tr>
        <td>
          <table role="presentation" class="container" width="100%">
            <!-- Image d'entête -->
            <tr>
              <td style="padding: 0">
                <div class="top-banner">
                  <img
                    src="https://image2url.com/r2/default/images/1770479134139-b31947fd-2090-4878-be9a-7a766b7fc572.jpg"
                    alt="Bannière Immo+"
                    style="max-width: 100%; height: auto"
                  />
                </div>
              </td>
            </tr>

            <!-- Titre -->
            <tr>
              <td class="header">
                <h1 style="margin: 0; font-size: 22px">
                  Bienvenue, {{prenom}} !
                </h1>
              </td>
            </tr>

            <!-- Contenu principal -->
            <tr>
              <td class="content">
                <p>
                  Merci de vous être inscrit(e) sur <strong>Immo+</strong>. Nous
                  sommes ravis de vous compter parmi nos utilisateurs.
                </p>
                <p>
                  Votre espace vous permet de rechercher, réserver et contacter
                  des professionnels rapidement.
                </p>
                <p style="text-align: center; margin: 22px 0">
                  <a class="btn" style="display:inline-block;background:#2745dc;color: #fff !important;padding:12px 20px;border-radius:6px;text-decoration:none;font-weight:700;" href="{{lien}}">Accéder à mon compte</a>
                </p>
                <p>
                  Si vous avez des questions, répondez simplement à cet email ou
                  consultez notre centre d'aide.
                </p>
                <p>Cordialement,<br />L'équipe Immo+</p>
              </td>
            </tr>

            <!-- Footer avec contact et unsubscribe -->
            <tr>
              <td class="footer">
                <strong>Coordonnées :</strong><br />
                Cocody Riviera 3, Abidjan, Côte d'Ivoire<br />
                Téléphone : 0701160450 / +225 0720154635<br />
                Site: <a href="https://immoplus.ci">immoplus.ci</a><br />
                Email :
                <a href="mailto:support@immoplus.ci">support@immoplus.ci</a
                ><br /><br />
                Vous recevez cet email car vous vous êtes inscrit(e) sur Immo+.
                <br />
                Pour vous désinscrire,
                <a href="{{unsubscribe_link}}">cliquez ici</a>.
              </td>
            </tr>

            <!-- Bannière finale -->
            <tr>
              <td style="padding: 0">
                <div class="final-banner-bottom">
                  <img
                    src="https://image2url.com/r2/default/images/1770479134139-b31947fd-2090-4878-be9a-7a766b7fc572.jpg"
                    alt="Bannière finale"
                    style="max-width: 100%; height: auto"
                  />
                </div>
              </td>
            </tr>
          </table>
        </td>
      </tr>
    </table>
  </body>
</html>
