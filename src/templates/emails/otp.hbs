<!doctype html>
<html lang="fr">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <title>Votre code OTP Immo+</title>
  <style>
    body{margin:0;padding:0;background:#f5f7fa;font-family:Arial,Helvetica,sans-serif;}
    .wrap{width:100%;background:#f5f7fa;padding:20px 0;}
    .container{max-width:600px;margin:0 auto;background:#fff;border-radius:12px;overflow:hidden;}
    .header{background:#2745dc;color:#fff;padding:28px;text-align:center;font-size:22px;font-weight:bold;}
    .top-banner, .final-banner-bottom{width:100%;overflow:hidden;}
    .top-banner img, .final-banner-bottom img{display:block;max-width:100%;height:auto;border:0;border-radius:12px 12px 0 0;}
    .final-banner-bottom img{border-radius:0 0 12px 12px;}
    .content{padding:28px;color:#333;font-size:16px;line-height:1.5;text-align:center;}
    .otp{display:flex;justify-content:center;gap:12px;margin:20px 0;}
    .otp div{background:#2745dc;color:#fff;font-size:24px;font-weight:bold;width:50px;height:50px;display:flex;align-items:center;justify-content:center;border-radius:8px;}
    .btn{display:inline-block;background:#2745dc;color:#fff;padding:12px 20px;border-radius:6px;text-decoration:none;font-weight:700;margin:18px 0;}
    .footer{padding:18px;text-align:center;font-size:13px;color:#777;line-height:1.5;}
    .footer a{color:#2745dc;text-decoration:none;}
    @media(max-width:480px){.content{padding:18px}.header{padding:20px}.otp div{width:40px;height:40px;font-size:20px;}}
  </style>
</head>
<body>
  <table role="presentation" class="wrap" width="100%">
    <tr>
      <td>
        <table role="presentation" class="container" width="100%">

          <!-- Bannière haut -->
          <tr>
            <td style="padding:0">
              <div class="top-banner">
                <img src="https://image2url.com/r2/default/images/1770479134139-b31947fd-2090-4878-be9a-7a766b7fc572.jpg" alt="Bannière Immo+" style="max-width:100%; height:auto;">
              </div>
            </td>
          </tr>

          <!-- Header -->
          <tr>
            <td class="header">🔒 Vérification de votre compte</td>
          </tr>

          <!-- Contenu principal -->
          <tr>
            <td class="content">
              <p>Bonjour {{prenom}},</p>
              <p>Voici votre code de vérification pour accéder à votre compte Immo+ :</p>

              <!-- OTP -->
              <div style="display:flex;justify-content:center;gap:12px;margin:20px 40px;">
                <div style="background:#2745dc;color:#fff;font-size:24px;font-weight:bold;width:50px;height:50px;border-radius:8px;margin-right:1rem;">
                  {{otpDigit1}}
                </div>
                <div style="background:#2745dc;color:#fff;font-size:24px;font-weight:bold;width:50px;height:50px;border-radius:8px;margin-right:1rem;">
                  {{otpDigit2}}
                </div>
                <div style="background:#2745dc;color:#fff;font-size:24px;font-weight:bold;width:50px;height:50px;border-radius:8px;margin-right:1rem;">
                  {{otpDigit3}}
                </div>
                <div style="background:#2745dc;color:#fff;font-size:24px;font-weight:bold;width:50px;height:50px;border-radius:8px;margin-right:1rem;">
                  {{otpDigit4}}
                </div>
                <div style="background:#2745dc;color:#fff;font-size:24px;font-weight:bold;width:50px;height:50px;border-radius:8px;margin-right:1rem;">
                  {{otpDigit5}}
                  </div>
                <div style="background:#2745dc;color:#fff;font-size:24px;font-weight:bold;width:50px;height:50px;border-radius:8px;margin-right:1rem;">
                  {{otpDigit6}}
                </div>
              </div>

              <p>💡 Ce code est valable pendant 10 minutes. Ne le partagez avec personne.</p>
              <p style="margin-top:20px;">Si vous n'avez pas demandé ce code, ignorez simplement cet email.</p>

              <p style="text-align:center;">
                <a class="btn" style="display:inline-block;background:#2745dc;color: #fff !important;;padding:12px 20px;border-radius:6px;text-decoration:none;font-weight:700;margin:18px 0;" href="{{lien}}">
                  Accéder à Immo+
                  </a>
                </p>
            </td>
          </tr>

          <!-- Footer avec contact et unsubscribe -->
          <tr>
            <td class="footer">
              <strong>Coordonnées :</strong><br>
              Cocody Riviera 3, Abidjan, Côte d'Ivoire<br>
              Téléphone : 0701160450 / +225 0720154635<br>
              Email : <a href="mailto:support@immoplus.ci">support@immoplus.ci</a><br><br>
              Vous recevez cet email car vous êtes inscrit(e) sur Immo+. <br>
              Pour vous désinscrire, <a href="{{unsubscribe_link}}">cliquez ici</a>.
            </td>
          </tr>

          <!-- Bannière bas -->
          <tr>
            <td style="padding:0">
              <div class="final-banner-bottom">
                <img src="https://image2url.com/r2/default/images/1770479134139-b31947fd-2090-4878-be9a-7a766b7fc572.jpg" alt="Bannière finale" style="max-width:100%; height:auto;">
              </div>
            </td>
          </tr>

        </table>
      </td>
    </tr>
  </table>
</body>
</html>
