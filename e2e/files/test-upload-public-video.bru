meta {
  name: test-upload-public-video
  type: http
  seq: 5
}

post {
  url: {{API_URL}}/files/public
  body: multipartForm
  auth: none
}

body:multipart-form {
  file: @file(uploads/sample-vid.mp4)
}

script:post-response {
  const { data: { id } }  = res.getBody();
    
  bru.setEnvVar("DEFAULT_FILE_ID", id);
  
}

tests {
  test("Should receive a not null id", function() {
    const {data: { id }} = res.getBody();
  
    expect(id).to.be.a('string');
  });
}
