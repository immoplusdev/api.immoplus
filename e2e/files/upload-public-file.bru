meta {
  name: upload-public-file
  type: http
  seq: 1
}

post {
  url: {{API_URL}}/files/public
  body: multipartForm
  auth: bearer
}

auth:bearer {
  token: {{DEFAULT_CUSTOMER_TOKEN}}
}

body:multipart-form {
  file: @file(/Users/monmackbook/Downloads/Ellipse 1.png)
}

script:post-response {
  const { data: { id } }  = res.getBody();
    
  bru.setEnvVar("DEFAULT_FILE_ID", id);
  
}
