meta {
  name: upload-public-file
  type: http
  seq: 1
}

post {
  url: {{API_URL}}/files/public
  body: multipartForm
  auth: bearer
}

auth:bearer {
  token: {{DEFAULT_CUSTOMER_TOKEN}}
}

body:multipart-form {
  file: @file(/Users/macbookpro/Downloads/03b0b16f-bebd-40ba-ab4c-e2b53b833376-85154fae-44db-41f4-85e0-6f8ddfb1535a.png)
}

script:post-response {
  
  
  const { data: { id } }  = res.getBody();
    
  bru.setEnvVar("DEFAULT_FILE_ID", id);
  
}
