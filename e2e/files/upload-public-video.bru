meta {
  name: upload-public-video
  type: http
  seq: 5
}

post {
  url: {{API_URL}}/files/public
  body: multipartForm
  auth: bearer
}

auth:bearer {
  token: {{DEFAULT_CUSTOMER_AT}}
}

body:multipart-form {
  file: @file(uploads/sample-vid.mp4)
}

script:post-response {
  const { data: { id } }  = res.getBody();
    
  bru.setEnvVar("DEFAULT_VIDEO_ID", id);
  
}
