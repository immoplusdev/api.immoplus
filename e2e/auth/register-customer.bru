meta {
  name: register-customer
  type: http
  seq: 3
}

post {
  url: {{API_URL}}/auth/register-customer
  body: json
  auth: none
}

body:json {
  {
    "avatar": "{{DEFAULT_APP_LOGO_ID}}",
    "email": "customer-{{$timestamp}}@immoplus.ci",
    "firstName": "{{$randomFirstName}}",
    "lastName": "{{$randomLastName}}",
    "phoneNumber": "225{{$timestamp}}",
    "password": "{{DEFAULT_USER_PASSWORD}}",
    "token": "{{DEFAULT_APP_OTP}}"
  }
}

script:post-response {
  const { data: { user: { id, phoneNumber, email }, accessToken, refreshToken } }  = res.getBody();
    
  bru.setEnvVar("DEFAULT_CUSTOMER_ID", id);
  bru.setEnvVar("DEFAULT_CUSTOMER_AT", accessToken);
  bru.setEnvVar("DEFAULT_CUSTOMER_RT", refreshToken);
  bru.setEnvVar("DEFAULT_CUSTOMER_PHONE", phoneNumber);
  bru.setEnvVar("DEFAULT_CUSTOMER_EMAIL", email);
}
