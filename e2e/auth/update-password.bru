meta {
  name: update-password
  type: http
  seq: 4
}

post {
  url: {{API_URL}}/auth/update-password
  body: json
  auth: bearer
}

auth:bearer {
  token: {{customerToken}}
}

body:json {
  {
    "oldPassword": "{{DEFAULT_USER_PASSWORD}}",
    "newPassword": "{{DEFAULT_USER_PASSWORD}}"
  }
}

tests {
  test("Should return 204 status code", function() {
    const status = res.getStatus();
    
    expect(status == 204).to.be.equal(true);
  });
  
}
