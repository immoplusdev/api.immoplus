meta {
  name: read-payment
  type: http
  seq: 3
}

get {
  url: {{API_URL}}/payments/{{DEFAULT_PAYMENT_ID}}
  body: none
  auth: bearer
}

auth:bearer {
  token: {{DEFAULT_CUSTOMER_AT}}
}

tests {
  const { z } = require("zod");
  
  const schema = z.object({
    id: z.string(),
    amount: z.number()
  });
  
  test("Should match schema", function() {
    
    const { data } = res.getBody();
    const result = schema.safeParse(data);
    expect(result.success).to.be.equal(true);
  });
}
