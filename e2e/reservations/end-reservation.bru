meta {
  name: end-reservation
  type: http
  seq: 11
}

patch {
  url: {{API_URL}}/reservations/{{DEFAULT_RESERVATION_ID}}
  body: json
  auth: bearer
}

auth:bearer {
  token: {{DEFAULT_CUSTOMER_AT}}
}

body:json {
  {
    "statusReservation": "terminee"
  }
}

script:pre-request {
  const { faker } = require('@faker-js/faker');
  bru.setVar("notes", faker.location.city());
}

tests {
  test("Should receive a none empty list of date objects", function() {
    const {data: { notes }} = res.getBody();
      
    expect(notes).to.be.a("string");
  });
}
